# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480
APP_NAME=amzur-ai-chat
ENVIRONMENT=production

# ── Database ───────────────────────────────────────────────────────────────────
# Render provides this automatically via the DATABASE_URL env var.
# For local dev, use: postgresql+asyncpg://user:pass@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Amzur LiteLLM Proxy ────────────────────────────────────────────────────────
LITELLM_PROXY_URL=https://litellm.amzur.com
LITELLM_API_KEY=sk-...
LLM_MODEL=gemini/gemini-2.5-flash
LITELLM_EMBEDDING_MODEL=text-embedding-3-large
IMAGE_GEN_MODEL=gemini/imagen-4.0-fast-generate-001

# ── Auth ────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://<your-backend>.onrender.com/api/auth/google/callback

# ── CORS ────────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=https://<your-project>.vercel.app
BACKEND_PUBLIC_URL=https://<your-backend>.onrender.com

# ── Storage (Render persistent disk paths) ─────────────────────────────────────
CHROMA_PERSIST_DIR=/opt/render/project/src/chroma_db
UPLOAD_DIR=/opt/render/project/src/uploads
MCP_DATA_DIR=/opt/render/project/src/data

# ── Optional APIs ───────────────────────────────────────────────────────────────
NEWSAPI_KEY=
CRICAPI_KEY=
THENEWSAPI_TOKEN=
TAVILY_API_KEY=
BREVO_API_KEY=
RESEND_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
